# MongoDB (ajusta usuario/puerto si aplica)
# - Mongo local sin autenticación:
MONGODB_URI=mongodb://127.0.0.1:27017/localizados_venezuela
# - Mongo en Docker CON autenticación (usuario root en la base `admin`):
#   añade credenciales y ?authSource=admin, p. ej.:
#   MONGODB_URI=mongodb://root:123456@localhost:27017/localizados_venezuela?authSource=admin

# URL pública del sitio (metadata, sitemap, enlaces al compartir)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Carpeta de uploads en desarrollo
UPLOAD_DIR=./public/uploads

